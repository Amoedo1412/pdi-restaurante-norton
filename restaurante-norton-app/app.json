{
  "expo": {
    "name": "Restaurante Norton",
    "slug": "restaurante-norton-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/RestauranteNorton.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/RestauranteNorton.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a" 
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.norton.restaurante"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a1a",
        "foregroundImage": "./assets/RestauranteNorton.png"
      },
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false,
      "package": "com.norton.restaurante",
      "statusBar": {
        "translucent": true,
        "barStyle": "light-content"
      },
      "navigationBar": {
        "visible": "sticky-immersive",
        "backgroundColor": "#00000000"
      }
    },
    "web": {
      "favicon": "./assets/RestauranteNorton.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}